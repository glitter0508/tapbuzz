.container {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; padding: 80rpx 40rpx 40rpx;
  background: #0f0f1a; color: #fff;
}

.status-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 40rpx; font-size: 28rpx; color: #888;
}
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #444; }
.dot.online { background: #4ade80; box-shadow: 0 0 16rpx #4ade8066; }

.title {
  font-size: 72rpx; font-weight: 700; margin-bottom: 8rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.subtitle { color: #666; font-size: 28rpx; margin-bottom: 60rpx; }

.loading-box { margin-top: 60rpx; }
.loading-text { color: #888; font-size: 30rpx; }

/* 分享卡片 */
.share-box {
  background: #1a1a2e; border-radius: 24rpx; padding: 40rpx;
  text-align: center; width: 100%; margin-bottom: 60rpx;
  display: flex; flex-direction: column; align-items: center;
}
.share-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.share-title { font-size: 36rpx; font-weight: 600; margin-bottom: 12rpx; }
.share-hint { color: #888; font-size: 26rpx; margin-bottom: 32rpx; }
.btn-share {
  width: 80%; padding: 24rpx; border-radius: 16rpx;
  font-size: 32rpx; font-weight: 600;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; margin: 0;
}

/* 按钮区域 */
.buzz-wrap { margin: 30rpx auto; display: flex; justify-content: center; }
.buzz-btn {
  width: 400rpx; height: 400rpx; border-radius: 50%; border: none;
  font-size: 48rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  box-shadow: 0 8rpx 40rpx #f5576c55;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  transition: transform .1s; margin: 0;
}
.buzz-btn:active { transform: scale(.9); }
.buzz-btn.disabled { opacity: .35; }
.buzz-btn-mini { width: 300rpx; height: 300rpx; }
.buzz-icon { font-size: 64rpx; margin-bottom: 8rpx; }
.buzz-label { font-size: 36rpx; }

.hint { color: #666; font-size: 26rpx; margin-top: 20rpx; }

@keyframes pulse {
  0% { transform: scale(1); box-shadow: 0 8rpx 40rpx #f5576c55; }
  15% { transform: scale(1.15); box-shadow: 0 0 80rpx #f5576c, 0 0 120rpx #f093fb88; }
  30% { transform: scale(.95); box-shadow: 0 0 60rpx #f5576c; }
  45% { transform: scale(1.1); box-shadow: 0 0 100rpx #f093fb; }
  60% { transform: scale(1); box-shadow: 0 8rpx 40rpx #f5576c55; }
}
.buzz-btn.receiving { animation: pulse .8s ease-out; }

/* 聊天入口 - 右下角悬浮按钮 */
.chat-bar {
  position: fixed; bottom: 120rpx; right: 40rpx;
  background: #1a1a2e; border: 2rpx solid #2a2a4a;
  padding: 20rpx 24rpx; border-radius: 40rpx;
  font-size: 28rpx; display: flex; align-items: center; gap: 10rpx;
  z-index: 50; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.4);
}
.chat-badge {
  background: #f5576c; color: #fff; font-size: 20rpx;
  min-width: 32rpx; height: 32rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 6rpx;
}

/* 聊天面板 */
.chat-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: #0f0f1a; z-index: 100;
  display: none; flex-direction: column;
}
.chat-overlay.show { display: flex; }

.chat-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 30rpx; border-bottom: 2rpx solid #2a2a4a;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}
.chat-header-title { font-size: 32rpx; font-weight: 600; }
.chat-close { font-size: 36rpx; padding: 8rpx; color: #888; }

.chat-body { flex: 1; overflow-y: auto; padding: 20rpx; }
.chat-msg-list { min-height: 100%; }
.chat-msg { margin-bottom: 24rpx; max-width: 80%; }
.chat-msg.me { margin-left: auto; text-align: right; }
.chat-msg.other { margin-right: auto; text-align: left; }

.chat-bubble {
  display: inline-block; padding: 16rpx 24rpx; border-radius: 16rpx;
  font-size: 28rpx; line-height: 1.5; word-break: break-word;
}
.chat-msg.me .chat-bubble {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-bottom-right-radius: 4rpx;
}
.chat-msg.other .chat-bubble {
  background: #1a1a2e; border-bottom-left-radius: 4rpx;
}
.chat-time { font-size: 20rpx; color: #555; margin-top: 6rpx; display: block; }
.chat-empty {
  text-align: center; color: #555; font-size: 26rpx;
  margin-top: 60rpx;
}

.chat-foot {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 20rpx; border-top: 2rpx solid #2a2a4a;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.chat-input {
  flex: 1; background: #1a1a2e; border: 2rpx solid #2a2a4a;
  border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx;
  color: #fff;
}
.chat-send {
  padding: 16rpx 32rpx; border-radius: 12rpx; font-size: 28rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; margin: 0; border: none;
}
