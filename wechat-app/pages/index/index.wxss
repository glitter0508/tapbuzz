.container {
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; padding: 80rpx 40rpx 40rpx;
  background: #0f0f1a; color: #fff;
}

.status-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 40rpx; font-size: 28rpx; color: #888;
}
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #444; }
.dot.online { background: #4ade80; box-shadow: 0 0 16rpx #4ade8066; }

.title {
  font-size: 72rpx; font-weight: 700; margin-bottom: 8rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.subtitle { color: #666; font-size: 28rpx; margin-bottom: 60rpx; }

.card { width: 100%; margin-bottom: 20rpx; }
.separator {
  display: flex; align-items: center; gap: 20rpx;
  color: #555; font-size: 26rpx; width: 100%; margin: 16rpx 0;
}
.separator::before, .separator::after {
  content: ''; flex: 1; height: 2rpx; background: #2a2a4a;
}

.input {
  width: 100%; padding: 28rpx; border: 2rpx solid #2a2a4a;
  border-radius: 16rpx; font-size: 36rpx; text-align: center;
  background: #0f0f1a; color: #fff; margin-bottom: 16rpx;
}

.btn-primary {
  width: 100%; padding: 28rpx; border: none; border-radius: 16rpx;
  font-size: 32rpx; font-weight: 600; color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  margin: 0;
}
.btn-primary:active { opacity: .8; }

.room-box {
  background: #1a1a2e; border-radius: 24rpx; padding: 40rpx;
  text-align: center; width: 100%; margin-bottom: 40rpx;
}
.room-label { font-size: 24rpx; color: #888; display: block; margin-bottom: 12rpx; }
.room-code { font-size: 64rpx; font-weight: 700; letter-spacing: 8rpx; color: #667eea; display: block; margin-bottom: 20rpx; }
.btn-share {
  padding: 16rpx 32rpx; border-radius: 12rpx; font-size: 26rpx;
  background: #667eea; color: #fff; display: inline-block; margin: 0;
}

.buzz-wrap { margin: 30rpx auto; display: flex; justify-content: center; }
.buzz-btn {
  width: 400rpx; height: 400rpx; border-radius: 50%; border: none;
  font-size: 48rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  box-shadow: 0 8rpx 40rpx #f5576c55;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  transition: transform .1s;
  margin: 0;
}
.buzz-btn:active { transform: scale(.9); }
.buzz-btn.disabled { opacity: .35; }
.buzz-icon { font-size: 64rpx; margin-bottom: 8rpx; }
.buzz-label { font-size: 36rpx; }

.hint { color: #666; font-size: 26rpx; margin-top: 20rpx; }

.btn-back {
  color: #666; font-size: 28rpx; margin-top: 40rpx; padding: 16rpx;
}

/* 振动动画 */
@keyframes pulse {
  0% { transform: scale(1); box-shadow: 0 8rpx 40rpx #f5576c55; }
  15% { transform: scale(1.15); box-shadow: 0 0 80rpx #f5576c, 0 0 120rpx #f093fb88; }
  30% { transform: scale(.95); box-shadow: 0 0 60rpx #f5576c; }
  45% { transform: scale(1.1); box-shadow: 0 0 100rpx #f093fb; }
  60% { transform: scale(1); box-shadow: 0 8rpx 40rpx #f5576c55; }
}
.buzz-btn.receiving { animation: pulse .8s ease-out; }
